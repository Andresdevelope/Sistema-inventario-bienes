APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
#username es correo
MAIL_USERNAME=null
#password generada desde la cuenta de correo para aplicaciones, no es la contraseña de la cuenta de correo es para aplicaciones, si usas gmail debes generar una contraseña de aplicación desde tu cuenta de google, si no sabes como hacerlo puedes buscar en google "generar contraseña de aplicación para gmail"
MAIL_PASSWORD=null
#encryption tls para gmail, si usas otro proveedor de correo verifica la configuración de encriptación que debes usar
MAIL_ENCRYPTION=tls
#correo desde el cual se enviarán los correos, debe ser el mismo que el username, si usas gmail debe ser tu cuenta de gmail
MAIL_FROM_ADDRESS="hello@example.com"
#nombre que aparecerá como remitente en los correos enviados, puedes cambiarlo por el nombre de tu aplicación o el nombre que desees
MAIL_FROM_NAME="Sistema Inventario De Bienes"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# si services esta en false pasalo a true para que se puedan usar los servicios de google el recaptcha config/services.php
# credenciales para el recaptcha de google y completa con tus claves de sitio y secretas obtenidas de google recaptcha, si no tienes una cuenta de google recaptcha puedes crearla en https://www.google.com/recaptcha/admin/create
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECOVERY_TOKEN_TTL_MINUTES=2
RECOVERY_TOKEN_MAX_ATTEMPTS=3
RECOVERY_TOKEN_REQUEST_INTERVAL=60
RECOVERY_TOKEN_MAX_RESENDS=3
